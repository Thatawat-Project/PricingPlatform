{
    "ReverseProxy": {
        "Routes": {
            "rules-route": {
                "ClusterId": "rules-cluster",
                "Match": { "Path": "/api/rules/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/api" } ]
            },
            "pricing-route": {
                "ClusterId": "pricing-cluster",
                "Match": { "Path": "/api/quotes/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/api" } ]
            }
        },
        "Clusters": {
            "rules-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://rules-service:8080" }
                }
            },
            "pricing-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://pricing-service:8080" }
                }
            }
        }
    }
}